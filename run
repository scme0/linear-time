#!/usr/bin/env bash
# run -- project task runner for Linear Time
#
# Usage:  ./run <command>
#
# Commands:
#   dev              Run the Flutter app on macOS (debug)
#   build            Build the macOS release app
#   codegen          Run build_runner code generation (Drift, Freezed)
#   codegen-watch    Run build_runner in watch mode
#   analyze          Run flutter analyze
#   test             Run all tests
#   install          Build release and copy to /Applications
#   clean            Delete build artefacts
#   help             Show this message

set -euo pipefail

export PATH="/opt/homebrew/bin:$PATH"

FLUTTER=flutter
DART=dart

cmd=${1:-help}
shift || true

case "$cmd" in

  dev)
    exec $FLUTTER run -d macos "$@"
    ;;

  build)
    COMMIT_SHA=$(git rev-parse --short HEAD)
    $FLUTTER build macos --release --dart-define=COMMIT_SHA="$COMMIT_SHA" "$@"
    echo "Built: build/macos/Build/Products/Release/Linear Time.app (${COMMIT_SHA})"
    ;;

  codegen)
    $DART run build_runner build --delete-conflicting-outputs "$@"
    ;;

  codegen-watch)
    $DART run build_runner watch --delete-conflicting-outputs "$@"
    ;;

  analyze)
    $FLUTTER analyze "$@"
    ;;

  test)
    $FLUTTER test "$@"
    ;;

  install)
    COMMIT_SHA=$(git rev-parse --short HEAD)
    $FLUTTER build macos --release --dart-define=COMMIT_SHA="$COMMIT_SHA" "$@"
    APP="build/macos/Build/Products/Release/Linear Time.app"
    rm -rf "/Applications/Linear Time.app"
    cp -R "$APP" "/Applications/Linear Time.app"
    echo "Installed to /Applications/Linear Time.app"
    ;;

  clean)
    $FLUTTER clean
    rm -rf macos/Pods macos/.symlinks macos/Podfile.lock
    echo "Cleaned."
    ;;

  help|--help|-h)
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    ;;

  *)
    echo "Unknown command: $cmd"
    echo "Run  ./run help  for usage."
    exit 1
    ;;

esac
